# Get your FREE API key from https://console.groq.com (no credit card needed)
GROQ_API_KEY=your-groq-api-key-here

# Admin panel password (pick anything you want)
ADMIN_PASSWORD=your-admin-password-here

# GitHub personal access token for publishing blog posts
# Create at: github.com/settings/tokens → New token → check "Contents" under repo
GITHUB_TOKEN=your-github-token-here
GITHUB_REPO=lw031505/nueraflowai.com
